/*--------------------------------*/
/* QPushButton */
/*--------------------------------*/
QPushButton
{
     color: rgb(253,245,230);
     background-color: rgb(53,53,53);
	 font:  9pt &quot;Open Sans Semibold&quot;;
}
QPushButton:disabled
{
