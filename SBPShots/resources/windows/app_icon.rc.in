// =====================================================================================================================
//  SBP Shots - Windows application resource (icon + version information).
//
//  This file is a CMake template. The @...@ placeholders are substituted at configure time from the CMake project
//  version, so the embedded version always matches PROJECT_VERSION. Do not edit the generated file in the build tree.
// =====================================================================================================================

#include <winver.h>

// Application icon (lowest-id icon becomes the executable icon in Windows Explorer).
IDI_ICON1 ICON "@SBPSHOTS_RC_ICON_PATH@"

// Version information shown in the file properties dialog.
VS_VERSION_INFO VERSIONINFO
    FILEVERSION     @SBPSHOTS_RC_VERSION_MAJOR@,@SBPSHOTS_RC_VERSION_MINOR@,@SBPSHOTS_RC_VERSION_PATCH@,0
    PRODUCTVERSION  @SBPSHOTS_RC_VERSION_MAJOR@,@SBPSHOTS_RC_VERSION_MINOR@,@SBPSHOTS_RC_VERSION_PATCH@,0
    FILEFLAGSMASK   VS_FFI_FILEFLAGSMASK
    FILEFLAGS       0x0L
    FILEOS          VOS_NT_WINDOWS32
    FILETYPE        VFT_APP
    FILESUBTYPE     VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "Real Instituto y Observatorio de la Armada (ROA)"
            VALUE "FileDescription",  "@PROJECT_DESCRIPTION@"
            VALUE "FileVersion",      "@PROJECT_VERSION@"
            VALUE "InternalName",     "@PROJECT_TARGET_NAME@"
            VALUE "LegalCopyright",   "Copyright (C) 2022-2026 Angel Vera Herrera (ROA). GNU GPL v3."
            VALUE "OriginalFilename", "@PROJECT_TARGET_NAME@.exe"
            VALUE "ProductName",      "@PROJECT_DISPLAY_NAME@"
            VALUE "ProductVersion",   "@PROJECT_VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        // US English (0x0409), Unicode code page (1200 = 0x04b0).
        VALUE "Translation", 0x409, 1200
    END
END
