          <property name="styleSheet">
           <string notr="true">/*--------------------------------*/
/* Auto Capture CheckBox */
/*--------------------------------*/

QCheckBox[accessibleName=&quot;AutoCaptureCheck&quot;]
{
    color: rgb(230, 230, 230);
    background-color: rgb(80, 35, 30);
    border: 2px solid rgb(150, 60, 45);
    border-radius: 6px;
    padding: 5px 8px 5px 8px;
    font: 14px &quot;Open Sans Extrabold&quot;;
}

QCheckBox[accessibleName=&quot;AutoCaptureCheck&quot;]:hover
{
    background-color: rgb(95, 42, 35);
    border: 2px solid rgb(180, 75, 55);
}

QCheckBox[accessibleName=&quot;AutoCaptureCheck&quot;]:checked
{
    color: rgb(255, 255, 255);
    background-color: rgb(35, 120, 25);
    border: 2px solid rgb(80, 220, 70);
}

QCheckBox[accessibleName=&quot;AutoCaptureCheck&quot;]:checked:hover
{
    background-color: rgb(45, 145, 30);
    border: 2px solid rgb(100, 245, 85);
}

QCheckBox[accessibleName=&quot;AutoCaptureCheck&quot;]:disabled
{
    color: rgb(100, 100, 100);
    background-color: rgb(45, 45, 45);
    border: 2px solid rgb(35, 35, 35);
}

QCheckBox[accessibleName=&quot;AutoCaptureCheck&quot;]::indicator
{
    width: 18px;
    height: 18px;
    border: 2px solid rgb(190, 190, 190);
    border-radius: 4px;
    background-color: rgb(40, 40, 40);
}

QCheckBox[accessibleName=&quot;AutoCaptureCheck&quot;]::indicator:unchecked
{
    background-color: rgb(120, 25, 15);
    border: 2px solid rgb(230, 90, 60);
}

QCheckBox[accessibleName=&quot;AutoCaptureCheck&quot;]::indicator:checked
{
    background-color: rgb(90, 240, 70);
    border: 2px solid rgb(230, 255, 220);
}

QCheckBox[accessibleName=&quot;AutoCaptureCheck&quot;]::indicator:disabled
{
    background-color: rgb(55, 55, 55);
    border: 2px solid rgb(80, 80, 80);
}

/*--------------------------------*/</string>
          </property>
          <property name="text">
           <string>AUTO OFF</string>
          </property>
          <property name="checked">
           <bool>false</bool>
          </property>
